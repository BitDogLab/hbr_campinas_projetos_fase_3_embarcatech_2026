// GATT Service Definition for RoboMovel
// UUID base: 0000FFxx-0000-1000-8000-00805F9B34FB

PRIMARY_SERVICE, GAP_SERVICE
CHARACTERISTIC, GAP_DEVICE_NAME, READ, "RoboMovel"

// Robot Control Service (UUID: 0000FF10-...)
PRIMARY_SERVICE, 0000FF10-0000-1000-8000-00805F9B34FB

// Command Characteristic (Write) - receives color commands
// UUID: 0000FF11-...
CHARACTERISTIC, 0000FF11-0000-1000-8000-00805F9B34FB, WRITE | WRITE_WITHOUT_RESPONSE | DYNAMIC,

// Status Characteristic (Read/Notify) - reports robot status
// UUID: 0000FF12-...
CHARACTERISTIC, 0000FF12-0000-1000-8000-00805F9B34FB, READ | NOTIFY | DYNAMIC,
