<!-- Botão estilizado em azul, preto e branco -->
<component>
	<api>
		<prop name="button_image" type="image" default="seta_esquerda" />
		<prop name="toggle" type="bool" default="false" />
		<prop name="checked" type="bool" default="false" />
	</api>

	<styles>
		<!-- Estilo base do botão -->
		<style
			name="style_base"
			bg_opa="100%"
			bg_color="0x1e1e2e"
			bg_grad_color="0x2a2a3a"
			border_color="0x1e90ff"
			border_width="2"
			radius="10"
			shadow_width="8"
			shadow_color="0x0a0a0a"
			pad_hor="#unit_large"
			pad_ver="#unit_medium"
			text_color="0xffffff"
			width="content"
			height="content"
		/>

		<!-- Estado pressionado -->
		<style
			name="style_pressed"
			bg_color="0x1e90ff"
			bg_grad_color="0x62a8ff"
			text_color="0x000000"
			border_color="0xffffff"
			recolor="0xffffff"
			recolor_opa="30%"
		/>

		<!-- Estado alternado (checked) -->
		<style
			name="style_checked"
			bg_color="0x0a84ff"
			bg_grad_color="0x1e90ff"
			border_color="0xffffff"
			text_color="0x000000"
		/>
	</styles>

	<animations>
		<!-- Efeito de entrada -->
		<timeline name="show_up">
			<animation target="self" prop="opa" start="0" end="255" duration="250" early_apply="true" />
			<animation target="self" prop="translate_y" start="15" end="0" duration="250" early_apply="true" />
		</timeline>
	</animations>

	<!-- Estrutura visual -->
	<view extends="lv_button" checked="$checked">
		<remove_style_all />
		<style name="style_base" />
		<style name="style_pressed" selector="pressed" />
		<style name="style_checked" selector="checked" />

		<lv_obj
			width="content"
			height="content"
			style_bg_opa="0"
			style_border_width="0"
			style_pad_all="0"
			scrollable="false"
			align="center"
		>
			<lv_image src="$button_image" align="center" style_recolor="0xffffff" style_recolor_opa="90%" />
		</lv_obj>
	</view>
</component>
